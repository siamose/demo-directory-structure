# -----------------------------------------------
# Dev Container
# -----------------------------------------------
CONTAINER_NAME=poc_dev

# -----------------------------------------------
# MLflow
# -----------------------------------------------
# ローカルファイルベースの場合: mlruns
# compose.yml経由でサーバーを立てる場合: http://mlflow:5000
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=poc_experiment
MLFLOW_PORT=5000

# -----------------------------------------------
# Streamlit
# -----------------------------------------------
STREAMLIT_PORT=8501

# -----------------------------------------------
# JupyterLab
# -----------------------------------------------
JUPYTER_PORT=8888

# -----------------------------------------------
# 外部API（必要に応じて追加）
# -----------------------------------------------
# OPENAI_API_KEY=
# OTHER_API_KEY=
