# -----------------------------------------------
# Dev Container
# -----------------------------------------------
# コンテナ名（任意。省略時はデフォルト名が使われる）
CONTAINER_NAME={{cookiecutter.project_slug}}_dev

# -----------------------------------------------
# MLflow（ローカルファイルベース・サーバー不要）
# -----------------------------------------------
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME={{cookiecutter.project_slug}}

# -----------------------------------------------
# Streamlit
# -----------------------------------------------
STREAMLIT_PORT=8501

# -----------------------------------------------
# JupyterLab
# -----------------------------------------------
JUPYTER_PORT=8888

# -----------------------------------------------
# 外部API（使用する場合のみ .env に値を記載）
# -----------------------------------------------
# OPENAI_API_KEY=
# OTHER_API_KEY=
